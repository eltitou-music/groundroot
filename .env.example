# GroundRoot — local env. Copy to .env and fill in (.env is gitignored).

# Supabase project (Anonymous auth provider MUST be enabled in the dashboard:
# Authentication → Providers → Anonymous). Without these the app can't start a session.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-ANON-PUBLISHABLE-KEY

# Optional: the real Stripe Payment Link for the €99 founders button.
# Falls back to a placeholder link if unset.
VITE_STRIPE_FOUNDERS_LINK=
